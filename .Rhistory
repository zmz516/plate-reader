# H2 is an outlier, condensation in the well?
fit_logistic <- nls(OD ~ SSlogis(Time_min, L, x0, scal), data = host-phage)
fit_logistic <- nls(OD ~ SSlogis(Time_min, L, x0, scal), data = hostphage)
summary(fit_logistic)
ggplot(data = hostphage, aes(x = Time_min, y = OD, colour = well)) +
geom_point(alpha = 0.5) +
geom_smooth(method = "nls",
formula = y ~ SSlogis(x, L, x0, scal),
se = FALSE,
color = "black",
linewidth = 1.2) +
